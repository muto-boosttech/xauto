# Anthropic（投稿生成）
ANTHROPIC_API_KEY=

# X API v2（OAuth 1.0a ユーザーコンテキスト）
# https://developer.x.com/en/portal/dashboard — tweet.read, tweet.write 等
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
# いずれかを設定（既存 Python ツール互換で X_ACCESS_TOKEN_SECRET）
X_ACCESS_SECRET=
X_ACCESS_TOKEN_SECRET=

# ブラウザ承認画面（node cli.js serve）の簡易ロック（空ならロックなし）
REVIEW_UI_TOKEN=

# ブラウザから「投稿案5件」を生成するボタンを出す（1 にすると表示）
XAUTO_UI_ALLOW_GENERATE=

# --- クラウド（Docker / Railway / Fly 等）---
# 永続ボリュームのマウント先（例: /data）
DATA_DIR=
# ログに出す HTTPS のベースURL（末尾スラッシュなし）
PUBLIC_BASE_URL=
# サーバの待受（クラウドでは通常 0.0.0.0）
HOST=0.0.0.0
# PORT は多くのホストが自動設定
